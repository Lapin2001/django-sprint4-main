from django.conf import settings
from django.conf.urls.static import static
from django.contrib import admin
from django.urls import path, include

# Импортируем view напрямую
from users.views import registration

urlpatterns = [
    path('admin/', admin.site.urls),
    path('', include('blog.urls', namespace='blog')),
    path('pages/', include('pages.urls', namespace='pages')),

    # Явный path для auth/registration/ (без namespace)
    path('auth/registration/', registration, name='registration'),

    # Остальные auth URLs (без namespace)
    path('auth/', include('django.contrib.auth.urls')),

    # Users URLs С namespace 'users'
    path('users/', include(('users.urls', 'users'), namespace='users')),
]

if settings.DEBUG:
    urlpatterns += static(
        settings.MEDIA_URL,
        document_root=settings.MEDIA_ROOT
    )
    urlpatterns += static(
        settings.STATIC_URL,
ч        document_root=settings.STATIC_ROOT
    )
# Custom error handlers
handler404 = 'pages.views.page_not_found'
handler500 = 'pages.views.server_error'
handler403 = 'pages.views.csrf_failure'
